import tkinter as tk

root = tk.Tk()
root.title("Iteration 2: The Button Grid")
root.geometry("400x400")

#the logic for the button grid
def change_color():
    root.configure(bg = "lightblue")

btn = tk.Button(root, text="Turn Blue", command=change_color)
btn.pack(pady=20) # adds some space around the button

root.mainloop()