import tkinter as tk

root=tk.Tk()
root.title("Iteration 4: Generating a greeting")
root.geometry("400x200")

#Capturing a user's name through text entry
def greetings():
    user_name=name_entry.get()
    result_label.config(text=f"Hello, {user_name}!")

#The entry(input box) widget
tk.Label(root, text="ENTER YOUR NAME: ").pack(pady=10)
name_entry=tk.Entry(root, font=("Arial", 14))
name_entry.pack(pady=5)

#The button widget triggers the greetings function when clicked
greet_btn=tk.Button(root, text="GREET ME!", command=greetings)
greet_btn.pack(pady=10)

#The label widget displays the greeting message
result_label=tk.Label(root, text="Waiting for your name...", font=("Arial", 12, "bold"), fg="blue")
result_label.pack(pady=10)

root.mainloop()