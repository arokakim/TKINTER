import tkinter as tk
import random

def generate_compliment():
    # 1. Capture the data from the Entries
    name = name_input.get()
    power = power_input.get()
    
    # 2. Logic: Create a list of silly adjectives
    adjectives = ["Magnificent", "Terrifying", "Sparkly", "Overpowered", "Bread-like"]
    adj = random.choice(adjectives)
    
    # 3. Update the 'Billboard' (The Result Label)
    message = f"{name}, the {adj}!\nPower Level: {power}"
    result_display.config(text=message)
    
    # 4. Change the background color just for fun
    colors = ["#FF5733", "#33FF57", "#3357FF", "#F333FF"]
    root.config(bg=random.choice(colors))

# --- SETTING THE STAGE ---
root = tk.Tk()
root.title("The Annoying Compliment Machine")
root.geometry("400x400")

# The 'Signposts' and 'Mailboxes'
tk.Label(root, text="WHO ARE YOU?", font=("Impact", 18)).pack(pady=10)
name_input = tk.Entry(root, justify="center") # justify centers the typing!
name_input.pack()

tk.Label(root, text="WHAT IS YOUR POWER LEVEL?").pack(pady=10)
power_input = tk.Entry(root, justify="center")
power_input.pack()

# The 'Trigger'
# Note: We don't use () when calling generate_compliment in the command!
trigger_btn = tk.Button(root, text="VALIDATE ME", command=generate_compliment, bg="black", fg="white")
trigger_btn.pack(pady=20)

# The 'Billboard'
result_display = tk.Label(root, text="Waiting to judge you...", font=("Arial", 14, "italic"))
result_display.pack(pady=20)

root.mainloop()